# Environment Variables for Transformer WAF
# Copy this file to .env and customize for your deployment

# ==================== Model Configuration ====================
WAF_MODEL_PATH=./models/waf_transformer
WAF_DEVICE=cpu  # Options: cpu, cuda
# WAF_MODEL_URL=https://example.com/waf_transformer_model.tar.gz

# ==================== Detection Settings ====================
WAF_ANOMALY_THRESHOLD=0.75  # Range: 0.0 - 1.0
WAF_CACHE_SIZE=10000
WAF_BATCH_SIZE=16

# ==================== API Settings ====================
WAF_API_HOST=0.0.0.0
WAF_API_PORT=8000

# ==================== Security Settings ====================
WAF_RATE_LIMIT=100  # Requests per window
WAF_RATE_LIMIT_WINDOW=60  # Seconds
WAF_MASK_PII=true  # Mask sensitive data in logs
# WAF_API_KEY=your-secret-api-key-here  # Optional API authentication

# ==================== Logging ====================
WAF_LOG_LEVEL=INFO  # Options: DEBUG, INFO, WARNING, ERROR
WAF_ALERT_LOG_FILE=./logs/alerts.jsonl
WAF_ACCESS_LOG_FILE=./logs/access.log

# ==================== Redis Cache (Optional) ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=changeme
REDIS_DB=0

# ==================== Database (Future) ====================
# DATABASE_URL=sqlite:///./data/waf_scans.db
# DATABASE_POOL_SIZE=10

# ==================== Frontend Dashboard ====================
VITE_API_URL=http://localhost:8000

# ==================== Production Settings ====================
# HTTPS_ENABLED=true
# SSL_CERT_PATH=./ssl/cert.pem
# SSL_KEY_PATH=./ssl/key.pem
# CORS_ORIGINS=https://dashboard.example.com

# ==================== Monitoring (Future) ====================
# PROMETHEUS_PORT=9090
# GRAFANA_PORT=3001
# SIEM_ENDPOINT=https://siem.example.com/ingest
